# Endereço do contrato TraceEdu (gerado por `npm run deploy:local`).
# Se preenchido aqui, sobrepõe o valor em src/constants/contract.js.
VITE_CONTRACT_ADDRESS=

# URL do backend (oráculo da SEFAZ). Padrão: http://localhost:3001
VITE_API_URL=http://localhost:3001

# CNPJ da escola/prefeitura (destinatário esperado da NF-e). Opcional na demo.
VITE_CNPJ_ESCOLA=

# ── Supabase (OPCIONAL) ──────────────────────────────────────────────────────
# Armazena os ARQUIVOS das notas fiscais off-chain (só o hash vai pra blockchain).
# Sem isso, o app funciona com verificação por hash (auditor reenvia o arquivo).
# Crie um bucket público chamado "notas-fiscais" no seu projeto Supabase.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_BUCKET=notas-fiscais
