# Porta da API
PORT=3001

# Provider da SEFAZ: "mock" (demo, sem certificado) ou "real" (produção)
SEFAZ_PROVIDER=mock

# ── Apenas para o provider REAL (produção) ───────────────────────────────────
# Caminho do certificado e-CNPJ (A1) e senha, OU token de uma API de terceiro.
# SEFAZ_CERT_PATH=
# SEFAZ_CERT_PASS=
# SEFAZ_API_TOKEN=
